# ============================================================
# Tracker Sales OS — Variables de entorno
# Copiar a .env y completar los valores reales
# NUNCA commitear .env al repositorio
# ============================================================

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=tracker
POSTGRES_PASSWORD=tracker123
POSTGRES_DB=tracker_sales_os

# --- NestJS Backend ---
PORT=3000
NODE_ENV=development

# --- JWT ---
JWT_SECRET=cambiar_esto_por_un_secreto_seguro_de_al_menos_32_chars
JWT_EXPIRES_IN=7d

# --- CORS ---
FRONTEND_URL=http://localhost:3001

# --- Anthropic (IA Coach — feature 12-ai-coach) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- TypeORM ---
TYPEORM_SYNCHRONIZE=false
TYPEORM_LOGGING=false
TYPEORM_MIGRATIONS_RUN=true

# --- Frontend (Vite) ---
VITE_API_URL=http://localhost:3000
