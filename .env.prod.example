# ============================================================
# Tracker Sales OS — Variables de entorno PRODUCCION
# Copiar a .env y completar con valores reales y seguros
# NUNCA commitear .env al repositorio
# ============================================================

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=tracker
POSTGRES_PASSWORD=CAMBIAR_PASSWORD_FUERTE_MIN32CHARS
POSTGRES_DB=tracker_sales_os

# --- NestJS Backend ---
PORT=3000
NODE_ENV=production

# --- JWT ---
JWT_SECRET=CAMBIAR_SECRETO_ALEATORIO_MIN64CHARS
JWT_EXPIRES_IN=7d

# --- CORS ---
FRONTEND_URL=https://tudominio.com

# --- Anthropic (IA Coach) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- TypeORM ---
TYPEORM_SYNCHRONIZE=false
TYPEORM_LOGGING=false
TYPEORM_MIGRATIONS_RUN=true

# --- Frontend (Vite — se bake en build time, no en runtime) ---
VITE_API_URL=https://tudominio.com
